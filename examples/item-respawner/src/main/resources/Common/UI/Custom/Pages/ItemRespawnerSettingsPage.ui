// Settings form for the Item Respawner block, opened by pressing F on the block.
// Reuses the game's shared UI templates from Common.ui ($C). Named elements
// (#Item, #IntervalSeconds, #SaveButton) are read/written from the Java page:
// build() seeds their .Value, and the SaveButton's Activating event sends those
// values back keyed for the page's event-data codec.
$C = "../Common.ui";

$C.@PageOverlay {
  LayoutMode: Middle;

  $C.@DecoratedContainer {
    Anchor: (Width: 420);

    #Title {
      $C.@Title {
        @Text = %server.customUI.itemRespawnerSettingsPage.title;
      }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Full: 16);

      Label {
        Anchor: (Bottom: 8);
        Text: %server.customUI.itemRespawnerSettingsPage.item;
        Style: (...$C.@DefaultLabelStyle, RenderBold: true);
      }

      $C.@TextField #Item {
        @Anchor = (Left: 0, Bottom: 8);
      }

      Label {
        Anchor: (Bottom: 8);
        Text: %server.customUI.itemRespawnerSettingsPage.intervalSeconds;
        Style: (...$C.@DefaultLabelStyle, RenderBold: true);
      }

      $C.@NumberField #IntervalSeconds {
        @Anchor = (Left: 0, Bottom: 8);
        Format: (MaxDecimalPlaces: 0, Step: 1);
      }

      Group {
        Anchor: (Vertical: 16, Height: 1);
        Background: #5e512c(0.0);
      }

      $C.@TextButton #SaveButton {
        Text: %server.customUI.saveChanges;
      }
    }
  }
}

$C.@BackButton {}
